{
  "name": "ethronics-cms-backend",
  "version": "1.0.0",
  "description": "Backend CMS for Ethronics website content management",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "echo 'No build step required'",
    "check-env": "node check-env.js",
    "prestart": "node check-env.js || true",
    "verify-admin": "node tests/verifyAdminUser.js",
    "seed": "node scripts/seedData.js",
    "seed-all-translations": "node seeds/seedAllTranslations.js",
    "seed-admin": "node seeds/seedAdminUser.js",
    "seed-everything": "node seeds/seedEverything.js",
    "seed-production": "node seeds/seedProductionDatabase.js",
    "seed-home": "node scripts/seedHomeData.js",
    "import-home": "node scripts/importHomeData.js",
    "seed-academic": "node scripts/seedAcademicData.js",
    "import-academic": "node scripts/importAcademicData.js",
    "import-academic-sections": "node scripts/importAcademicSections.js",
    "import-about": "node scripts/importAboutData.js",
    "migrate-academic": "node scripts/migrateAcademicToSections.js",
    "check-academic": "node scripts/checkAcademicSections.js",
    "test-structure": "node scripts/testDataStructure.js",
    "upload-images": "node scripts/uploadImagesToCloudinary.js",
    "update-db-urls": "node scripts/updateDatabaseWithCloudinaryUrls.js",
    "add-images": "node scripts/addImagesToContent.js",
    "test-cloudinary": "node scripts/testCloudinaryConnection.js",
    "seed-careers": "node seeds/seedCareersContent.js"
  },
  "keywords": [
    "cms",
    "backend",
    "ethronics"
  ],
  "author": "Ethronics",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^8.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
